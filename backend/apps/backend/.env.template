STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
JWT_SECRET=
COOKIE_SECRET=
DATABASE_URL=

# Redis — required in every environment; this project never runs on
# Medusa's in-memory dev defaults (see docs/ROADMAP.md Phase 1).
REDIS_URL=redis://localhost:6379
EVENTS_REDIS_URL=redis://localhost:6379
WE_REDIS_URL=redis://localhost:6379
LOCKING_REDIS_URL=redis://localhost:6379
CACHE_REDIS_URL=redis://localhost:6379

# Paystack (MEDUSA_EXTENSIONS.md #4, approved) — optional. Leave unset and
# the store keeps working on the native placeholder provider
# (pp_system_default) only. Once set and the backend is restarted, the
# Paystack payment provider registers automatically (medusa-config.ts) —
# it still needs one manual step to become selectable at checkout:
# POST /admin/regions/:id with {"payment_providers": ["pp_system_default", "pp_paystack_paystack"]}.
# Get this from the Paystack dashboard → Settings → API Keys & Webhooks.
# Also register a webhook there pointing at this backend's payment
# webhook URL, using the same secret key for signature verification.
PAYSTACK_SECRET_KEY=

# Email notifications via SendGrid (MEDUSA_EXTENSIONS.md #5, approved
# channel). Optional — leave unset and no email is sent (the order-
# confirmation subscriber logs a specific, honest failure instead of
# silently no-op'ing). Both must be set together.
# SENDGRID_API_KEY: SendGrid dashboard → Settings → API Keys.
# SENDGRID_FROM: a sender address verified in SendGrid (Settings →
# Sender Authentication) — required or SendGrid will reject the send.
SENDGRID_API_KEY=
SENDGRID_FROM=

# WhatsApp notifications via Meta's WhatsApp Cloud API
# (MEDUSA_EXTENSIONS.md #5, approved channel). Optional — both must be
# set together. Every message this project sends is business-initiated,
# so it must use a pre-approved WhatsApp message template (Meta Business
# Manager → WhatsApp Manager → Message Templates) — free-form text is
# rejected outside a customer-initiated 24-hour window.
# WHATSAPP_ACCESS_TOKEN: a permanent access token for your WhatsApp
# Business app (Meta Business Manager → System Users, not the 24-hour
# temporary token from the Cloud API quickstart).
# WHATSAPP_PHONE_NUMBER_ID: found on the same app's WhatsApp → API Setup
# page, next to the sending phone number.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_LANGUAGE_CODE=en_US
